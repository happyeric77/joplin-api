# WebDAV sync configuration (required)
JOPLIN_WEBDAV_URL=https://your-synology:5006/remote.php/dav/files/user/Notes
JOPLIN_WEBDAV_USER=your-username
JOPLIN_WEBDAV_PASS=your-password

# Joplin API authentication (required)
JOPLIN_API_TOKEN=your-api-token

# Profile directory (optional, default: /data/joplin-profile)
# JOPLIN_PROFILE_DIR=/data/joplin-profile

# Sync interval in minutes (optional, default: 10; overridden by PERIODIC_SYNC_INTERVAL_SECONDS)
JOPLIN_SYNC_INTERVAL=10

# Advanced: periodic sync interval in seconds (optional, overrides JOPLIN_SYNC_INTERVAL)
# JOPLIN_PERIODIC_SYNC_INTERVAL_SECONDS=600

# Event polling interval in seconds (optional, default: 15)
# JOPLIN_EVENT_POLL_INTERVAL_SECONDS=15

# Event sync debounce in seconds (optional, default: 30)
# JOPLIN_EVENT_SYNC_DEBOUNCE_SECONDS=30
